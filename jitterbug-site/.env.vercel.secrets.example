# Copy to .env.vercel.secrets in jitterbug-site/ (gitignored).
# Then: node scripts/push-env-to-vercel.mjs && npm run deploy:vercel
#
# Neon — Dashboard → copy connection string (pooled recommended for serverless)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# STRIPE_* — Dashboard → Developers → API keys (secret key) and Webhooks (signing secret)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional — Google FCM (server only). Legacy: FIREBASE_SERVICE_ACCOUNT_JSON
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional — if omitted, push-env-to-vercel.mjs generates one (sync iOS Info.plist InternalNewBookingNotifySecret)
# INTERNAL_NEW_BOOKING_NOTIFY_SECRET=
