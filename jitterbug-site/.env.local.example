# Copy to .env.local (never commit .env.local).
# Server secrets for Vercel: copy .env.vercel.secrets.example → .env.vercel.secrets, then `npm run vercel:push-env`.
#
# The web app does NOT use Firebase in the browser (no NEXT_PUBLIC_FIREBASE_*).
#
# Admin login (also sent as x-admin-* headers to /api/data/*)
# NEXT_PUBLIC_ADMIN_EMAIL=
# NEXT_PUBLIC_ADMIN_PASSWORD=

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional — Google FCM (server only); legacy name FIREBASE_SERVICE_ACCOUNT_JSON also works
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional: iOS notify-new-booking (match Info.plist InternalNewBookingNotifySecret)
INTERNAL_NEW_BOOKING_NOTIFY_SECRET=
