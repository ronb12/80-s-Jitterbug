{
  "name": "jitterbug-functions",
  "description": "Cloud Functions for 80's Jitterbug (e.g. email on new booking)",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "resend": "^4.0.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "private": true
}
