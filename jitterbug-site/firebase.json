{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "trailingSlash": true,
    "rewrites": [
      {
        "source": "/api/stripeCheckout",
        "function": {
          "functionId": "stripeCheckout",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/stripeWebhook",
        "function": {
          "functionId": "stripeWebhook",
          "region": "us-central1"
        }
      }
    ]
  }
}
